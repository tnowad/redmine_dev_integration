<%= l(:text_pr_reviewed_notification, number: @pull_request.number, state: @review_state) %>

<%= l(:label_pr_details) %>:
* <%= l(:field_status) %>: <%= @pull_request.state %>
* <%= l(:label_repository) %>: <%= @pull_request.external_repository.full_name %>
* <%= l(:label_source_branch) %>: <%= @pull_request.source_branch %>
* <%= l(:label_target_branch) %>: <%= @pull_request.target_branch %>
* <%= l(:label_review_state) %>: <%= @review_state %>

<% if @issues.any? %>
<%= l(:label_linked_issues) %>:
<% @issues.each do |issue| %>
  * #<%= issue.id %>: <%= issue.subject %>
<% end %>
<% end %>

<% if @pr_url.present? %>
<%= l(:label_view_pr) %>: <%= @pr_url %>
<% end %>
