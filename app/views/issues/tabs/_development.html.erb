<%
  development_panel_data = @development_panel_data
  development_panel_data ||= RedmineDevIntegration::IssueDevelopmentPanelData.new(@issue) if defined?(RedmineDevIntegration::IssueDevelopmentPanelData)
  development_panel_setting =
    if @issue&.project&.respond_to?(:development_integration_project_setting)
      @issue.project.development_integration_project_setting || DevelopmentIntegrationProjectSetting.for_project(@issue.project)
    end
  show_builds = development_panel_setting.nil? || development_panel_setting.show_builds != false
  show_deployments = development_panel_setting.nil? || development_panel_setting.show_deployments != false
  branches = development_panel_data&.branches || []
  scm_branches = development_panel_data&.scm_branches || []
  commits = development_panel_data&.commits || []
  external_commits = development_panel_data&.external_commits || []
  builds = show_builds ? development_panel_data&.builds : []
  deployments = show_deployments ? development_panel_data&.deployments : []
  releases = development_panel_data&.releases || []
  pull_requests = development_panel_data&.pull_requests || []
  incidents = development_panel_data&.incidents || []
%>

<%= call_hook(:view_issues_show_details_bottom, issue: @issue) %>

<div id="development-integration">
  <div>
    <% if commits.any? || external_commits.any? %>
      <h3><%= l(:label_revision_plural) %></h3>
      <div class="journals">
        <% external_commits.each do |commit| %>
          <div id="external-commit-<%= commit.id %>" class="changeset journal">
            <h4 class="journal-header">
              <span class="journal-info">
                <%= avatar(nil, size: "24") %>
                <%= h(commit.author_login.presence || commit.author_name.presence || '') %>
              </span>
              <span class="journal-meta">
                <span class="journal-actions">
                  <% if commit.url.present? %>
                    <%= link_to sprite_icon('link', l(:label_redmine_dev_integration_open_in_provider)),
                                commit.url,
                                target: '_blank',
                                rel: 'noopener',
                                class: 'icon-only icon-link' %>
                  <% end %>
                </span>
                <span class="journal-link"><%= h(commit.short_sha.presence || commit.sha.to_s.first(7)) %></span>
              </span>
            </h4>
            <div class="journal-content">
              <p>
                <%= h(commit.branch_name) %> ·
                <%= h(commit.external_repository.provider) %>/<%= h(commit.external_repository.full_name) %>
                <% if commit.committed_at.present? %>
                  · <%= format_time(commit.committed_at) %>
                <% end %>
              </p>
              <div class="wiki">
                <%= textilizable(commit.message) %>
              </div>
            </div>
          </div>
        <% end %>
        <% commits.each do |changeset| %>
          <div id="changeset-<%= changeset.id %>" class="changeset journal">
            <h4 class="journal-header">
              <span class="journal-info">
                <%= avatar(changeset.user, size: "24") %>
                <%= authoring changeset.committed_on, changeset.author, label: :label_added_time_by %>
              </span>
            </h4>
            <div class="journal-content">
              <p>
                <%= link_to_revision(changeset, changeset.repository, text: format_revision(changeset)) %>
              </p>
              <div class="wiki changeset-comments">
                <%= format_changeset_comments changeset %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="nodata"><%= l(:label_no_data) %></p>
    <% end %>
  </div>

  <div>
    <% if @issue.project.external_repositories.active.exists? %>
      <div class="contextual">
        <%= link_to sprite_icon('add', l(:label_create_branch)),
                    '#',
                    class: 'icon icon-add',
                    id: 'create-branch-link',
                    onclick: 'showBranchForm(); return false;' %>
      </div>
      <div id="create-branch-form" style="display:none;">
        <% if flash[:error].present? %>
          <div id="errorExplanation"><ul><li><%= flash[:error] %></li></ul></div>
        <% end %>
        <%= form_tag create_branch_dev_integration_path(@issue.project, @issue), method: :get do %>
          <div class="box tabular">
            <p>
              <%= label_tag :repository_id, l(:label_repository) %>
              <%= select_tag :repository_id,
                    options_from_collection_for_select(@issue.project.external_repositories.active, :id, :full_name) %>
            </p>
            <p>
              <%= label_tag :prefix, l(:label_branch_prefix) %>
              <%= text_field_tag :prefix, 'feature', size: 20 %>
              <em class="info"><%= l(:text_create_branch_help) %></em>
            </p>
            <p>
              <%= submit_tag l(:button_create) %>
              <%= link_to l(:button_cancel), '#', onclick: 'hideBranchForm(); return false;' %>
            </p>
          </div>
        <% end %>
      </div>
    <% end %>
    <% if branches.any? || scm_branches.any? %>
      <h3><%= l(:label_branch) %></h3>
      <div class="journals">
        <% branches.each do |branch| %>
          <div id="branch-<%= branch.id %>" class="changeset journal">
            <h4 class="journal-header">
              <span class="journal-info"><%= h(branch.name) %></span>
              <span class="journal-meta">
                <span class="journal-actions">
                  <% if branch.url.present? %>
                    <%= link_to sprite_icon('link', l(:label_redmine_dev_integration_open_in_provider)),
                                branch.url,
                                target: '_blank',
                                rel: 'noopener',
                                class: 'icon-only icon-link' %>
                  <% end %>
                </span>
                <span class="journal-link"><%= h(branch.state) %></span>
              </span>
            </h4>
            <div class="journal-content">
              <ul class="journal-details">
                <li><%= h(branch.external_repository.provider) %> / <%= h(branch.external_repository.full_name) %></li>
                <% if branch.sha.present? %><li><%= h(branch.sha.to_s.first(7)) %></li><% end %>
                <li><%= format_time(branch.updated_at) %></li>
              </ul>
            </div>
          </div>
        <% end %>
        <% scm_branches.each do |branch| %>
          <div class="changeset journal">
            <h4 class="journal-header">
              <span class="journal-info">
                <%= link_to h(branch.name),
                            controller: 'repositories',
                            action: 'show',
                            id: @issue.project,
                            repository_id: branch.repository.identifier_param,
                            rev: branch.name %>
              </span>
              <span class="journal-meta">
                <span class="journal-link"><%= h(branch.state) %></span>
              </span>
            </h4>
            <div class="journal-content">
              <ul class="journal-details">
                <li><%= l(:label_scm) %> / <%= h(branch.repository.identifier.presence || 'root') %></li>
              </ul>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="nodata"><%= l(:label_no_data) %></p>
    <% end %>
  </div>

  <% if show_builds %>
  <div>
    <% if builds.any? %>
      <h3><%= l(:label_build_plural) %></h3>
      <div class="journals">
        <% builds.each do |build| %>
          <div id="build-<%= build.id %>" class="changeset journal">
            <h4 class="journal-header">
              <span class="journal-info">
                <strong><%= h(build.name) %></strong>
                <span class="badge badge-status-<%= case build.status when 'success' then 'closed' when 'failed' then 'private' else 'open' end %>"><%= l("label_build_status_#{build.status}".to_sym) %></span>
              </span>
              <span class="journal-meta">
                <span class="journal-actions">
                  <% if build.url.present? %>
                    <%= link_to sprite_icon('link', l(:label_redmine_dev_integration_open_in_provider)),
                                build.url,
                                target: '_blank',
                                rel: 'noopener',
                                class: 'icon-only icon-link' %>
                  <% end %>
                </span>
              </span>
            </h4>
            <div class="journal-content">
              <ul class="journal-details">
                <li><%= h(build.ref.presence || build.branch_name) %></li>
                <li><%= h(build.sha.to_s.first(7)) %></li>
                <li><%= h(build.external_repository.provider) %> / <%= h(build.external_repository.full_name) %></li>
                <% if build.started_at.present? || build.finished_at.present? %>
                  <li><%= format_time(build.started_at) if build.started_at.present? %><%= build.started_at.present? && build.finished_at.present? ? ' - ' : '' %><%= format_time(build.finished_at) if build.finished_at.present? %></li>
                <% end %>
              </ul>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="nodata"><%= l(:label_no_data) %></p>
    <% end %>
  </div>
  <% end %>

  <% if show_deployments %>
  <div>
    <% if deployments.any? %>
      <h3><%= l(:label_deployment_plural) %></h3>
      <div class="journals">
        <% deployments.each do |deployment| %>
          <div id="deployment-<%= deployment.id %>" class="changeset journal">
            <h4 class="journal-header">
              <span class="journal-info">
                <strong><%= h(deployment.environment_name) %></strong>
                <% if deployment.rollback? %>
                  <span class="badge badge-status-locked"><%= l(:label_rollback) %></span>
                <% end %>
                <span class="badge badge-status-<%= case deployment.status when 'success' then 'closed' when 'failed' then 'private' else 'open' end %>"><%= l("label_deployment_status_#{deployment.status}".to_sym) %></span>
              </span>
              <span class="journal-meta">
                <span class="journal-actions">
                  <% if deployment.environment_url.present? %>
                    <%= link_to sprite_icon('link', l(:label_redmine_dev_integration_open_in_provider)),
                                deployment.environment_url,
                                target: '_blank',
                                rel: 'noopener',
                                class: 'icon-only icon-link' %>
                  <% end %>
                </span>
              </span>
            </h4>
            <div class="journal-content">
              <ul class="journal-details">
                <li><%= h(deployment.ref.presence || deployment.branch_name) %></li>
                <li><%= h(deployment.sha.to_s.first(7)) %></li>
                <li><%= h(deployment.external_repository.provider) %> / <%= h(deployment.external_repository.full_name) %></li>
                <li><%= format_time(deployment.completed_at) if deployment.completed_at.present? %></li>
              </ul>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="nodata"><%= l(:label_no_data) %></p>
    <% end %>
  </div>
  <% end %>

  <div>
    <% if releases.any? %>
      <h3><%= l(:label_release_plural) %></h3>
      <div class="journals">
        <% releases.each do |release| %>
          <div id="release-<%= release.id %>" class="changeset journal">
            <h4 class="journal-header">
              <span class="journal-info">
                <strong><%= h(release.name) %></strong>
              </span>
              <span class="journal-meta">
                <span class="journal-actions">
                  <% if release.url.present? %>
                    <%= link_to sprite_icon('link', l(:label_redmine_dev_integration_open_in_provider)),
                                release.url,
                                target: '_blank',
                                rel: 'noopener',
                                class: 'icon-only icon-link' %>
                  <% end %>
                </span>
              </span>
            </h4>
            <div class="journal-content">
              <ul class="journal-details">
                <% if release.tag_name.present? %><li><%= h(release.tag_name) %></li><% end %>
                <li><%= h(release.provider) %> / <%= h(release.external_repository.full_name) %></li>
                <% if release.author_login.present? %><li><%= h(release.author_login) %></li><% end %>
                <li><%= format_time(release.released_at) if release.released_at.present? %></li>
              </ul>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="nodata"><%= l(:label_no_data_releases) %></p>
    <% end %>
  </div>

  <div>
    <% if incidents.any? %>
      <h3><%= l(:label_incident_plural) %></h3>
      <div class="journals">
        <% incidents.each do |incident| %>
          <div id="incident-<%= incident.id %>" class="changeset journal">
            <h4 class="journal-header">
              <span class="journal-info">
                <strong><%= h(incident.title) %></strong>
                <span class="badge badge-status-<%= incident.status == 'resolved' ? 'closed' : 'private' %>"><%= h(incident.status) %></span>
              </span>
            </h4>
            <div class="journal-content">
              <ul class="journal-details">
                <li><%= l(:field_severity) %>: <%= h(incident.severity) %></li>
                <% if incident.duration_hours %>
                  <li><%= l(:label_duration) %>: <%= incident.duration_hours %>h</li>
                <% end %>
              </ul>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div>
    <% if pull_requests.any? %>
      <h3><%= l(:label_pull_request_plural) %></h3>
      <div class="journals">
        <% pull_requests.each do |pull_request| %>
          <div id="pr-<%= pull_request.id %>" class="changeset journal">
            <h4 class="journal-header">
              <span class="journal-info">
                <strong>#<%= pull_request.number %></strong>
                <%= h(pull_request.title) %>
              </span>
              <span class="journal-meta">
                <span class="journal-actions">
                  <% if pull_request.url.present? %>
                    <%= link_to sprite_icon('link', l(:label_redmine_dev_integration_open_in_provider)),
                                pull_request.url,
                                target: '_blank',
                                rel: 'noopener',
                                class: 'icon-only icon-link' %>
                  <% end %>
                </span>
                <span class="journal-link"><%= l("label_pr_state_#{pull_request.state}".to_sym) %><%= pull_request.merged ? " / #{l(:label_merged)}" : '' %></span>
                <% review_state = pull_request.review_state %>
                <% if review_state.present? %>
                  <span class="badge badge-status-<%= case review_state.downcase when 'approved' then 'closed' when 'changes_requested' then 'private' else 'open' end %>"><%= l("label_review_state_#{review_state}".to_sym) %></span>
                <% end %>
                <% approved = pull_request.approved_count %>
                <% if approved > 0 %>
                  <span class="journal-link"><%= approved %> <%= l(:label_review_approved) %></span>
                <% end %>
              </span>
            </h4>
            <div class="journal-content">
              <ul class="journal-details">
                <li><%= h(pull_request.provider) %> / <%= h(pull_request.external_repository.full_name) %></li>
                <% if pull_request.author_login.present? %><li><%= h(pull_request.author_login) %></li><% end %>
                <% if pull_request.source_branch.present? || pull_request.target_branch.present? %>
                  <li><%= h([pull_request.source_branch, pull_request.target_branch].compact.join(' -> ')) %></li>
                <% end %>
                <li><%= format_time(pull_request.last_event_at || pull_request.updated_at) %></li>
              </ul>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="nodata"><%= l(:label_no_data) %></p>
    <% end %>
  </div>
</div>

<%= javascript_tag do %>
  function showBranchForm() {
    document.getElementById('create-branch-form').style.display = '';
    document.getElementById('create-branch-link').style.display = 'none';
  }
  function hideBranchForm() {
    document.getElementById('create-branch-form').style.display = 'none';
    document.getElementById('create-branch-link').style.display = '';
  }
<% end %>
